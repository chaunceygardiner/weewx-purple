# Coverage config for the weewx-purple test suite:
#   PYTHONPATH=bin python -m coverage run -m pytest tests && python -m coverage report -m
[run]
branch = True
include = */user/purple.py

[report]
exclude_lines =
    pragma: no cover
    # The __main__ block is the manual harness (--test-is-sane /
    # --test-collector); it only runs as a script against a live sensor.
    if __name__ == .__main__.:
